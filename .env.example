POSTGRES_DB=family_finance
POSTGRES_USER=family_finance_user
POSTGRES_PASSWORD=change_me_to_a_strong_password
POSTGRES_PORT=5432
POSTGRES_BIND_ADDRESS=127.0.0.1

WEB_PORT=8000
WEB_BIND_ADDRESS=127.0.0.1
DJANGO_SECRET_KEY=change_me_to_a_random_secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,nas-ip
# For an HTTPS reverse proxy, use the public origin, for example:
# DJANGO_CSRF_TRUSTED_ORIGINS=https://finance.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=
DJANGO_SECURE_PROXY_SSL_HEADER=False
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SESSION_COOKIE_SECURE=False
DJANGO_CSRF_COOKIE_SECURE=False
# Enable HSTS only after HTTPS is working correctly.
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=False
DJANGO_SECURE_HSTS_PRELOAD=False

DATABASE_URL=postgres://family_finance_user:change_me_to_a_strong_password@db:5432/family_finance

# AI provider API keys must live in environment variables, not AiProvider.extra_data.
# 智谱图片识别
ZHIPU_API_KEY=
# 火山方舟（豆包）图片识别
ARK_API_KEY=
# 其他 OpenAI 兼容服务
OPENAI_API_KEY=
AI_API_KEY=

# 默认使用 Docker Hub 官方 Python 镜像。
# 如果你的网络无法访问 Docker Hub，可以改成你可访问的镜像源或私有镜像。
PYTHON_IMAGE=python:3.12-slim
